---
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>Rocamar — Casa de playa con vista al mar · Playa Blanca, Costa Rica</title>
  <meta name="description" content="Rocamar: una casa de playa con tres apartamentos independientes en Playa Blanca, Costa Rica. Vista al Pacífico, a 50 m del mar y 10 min caminando a la playa. Alquílalos por separado o todos juntos. Reservas con Rentas Pura Vida.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg:      oklch(98% 0.006 85);
      --surface: oklch(100% 0 0);
      --surface-2: oklch(96% 0.008 85);
      --fg:      oklch(22% 0.04 220);
      --fg-soft: oklch(32% 0.035 220);
      --muted:   oklch(48% 0.018 220);
      --border:  oklch(89% 0.012 200);
      --border-strong: oklch(78% 0.018 200);
      --accent:  oklch(58% 0.13 200);
      --accent-deep: oklch(46% 0.13 210);
      --coral:   oklch(68% 0.15 35);
      --ocean-50: oklch(96% 0.018 200);
      --sand-50: oklch(95% 0.018 85);

      --font-display: 'Cormorant Garamond', 'Iowan Old Style', Georgia, serif;
      --font-body: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', system-ui, sans-serif;
      --font-mono: ui-monospace, 'JetBrains Mono', 'IBM Plex Mono', Menlo, monospace;

      --radius-sm: 8px;
      --radius: 14px;
      --radius-lg: 22px;

      --shadow-1: 0 1px 0 oklch(20% 0.03 220 / .04), 0 12px 32px -16px oklch(20% 0.03 220 / .10);

      --space-section: clamp(72px, 9vw, 128px);
    }

    *,*::before,*::after{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      background:var(--bg);
      color:var(--fg);
      font-family:var(--font-body);
      font-size:16px;
      line-height:1.55;
      -webkit-font-smoothing:antialiased;
      text-rendering:optimizeLegibility;
      text-wrap:pretty;
    }
    img{max-width:100%;display:block}
    a{color:inherit;text-decoration:none}
    button{font:inherit;cursor:pointer;border:0;background:none;color:inherit}

    .wrap{
      width:100%;
      max-width:1240px;
      margin-inline:auto;
      padding-inline:clamp(20px, 4vw, 48px);
    }

    /* ── Type ────────────────────────────────────────────── */
    .display{
      font-family:var(--font-display);
      font-weight:500;
      line-height:1.05;
      letter-spacing:-0.015em;
      color:var(--fg);
    }
    .eyebrow{
      font-family:var(--font-mono);
      font-size:11px;
      letter-spacing:0.14em;
      text-transform:uppercase;
      color:var(--accent-deep);
      display:inline-flex;
      align-items:center;
      gap:10px;
    }
    .eyebrow::before{
      content:"";
      width:24px;height:1px;
      background:currentColor;
    }
    .kicker{
      font-family:var(--font-mono);
      font-size:11px;
      letter-spacing:0.12em;
      text-transform:uppercase;
      color:var(--muted);
    }
    .lead{
      font-size:clamp(17px, 1.6vw, 19px);
      line-height:1.55;
      color:var(--fg-soft);
      max-width:62ch;
    }

    /* ── Nav ─────────────────────────────────────────────── */
    .nav{
      position:sticky; top:0; z-index:50;
      background:color-mix(in oklch, var(--bg) 88%, transparent);
      backdrop-filter:saturate(160%) blur(12px);
      -webkit-backdrop-filter:saturate(160%) blur(12px);
      border-bottom:1px solid color-mix(in oklch, var(--border) 70%, transparent);
    }
    .nav-inner{
      display:flex; align-items:center; justify-content:space-between;
      padding-block:18px;
    }
    .brand{
      display:inline-flex; align-items:center; gap:10px;
      font-family:var(--font-display);
      font-size:24px; font-weight:600;
      letter-spacing:-0.01em;
    }
    .brand-dot{
      width:10px;height:10px;border-radius:50%;
      background:var(--accent);
      box-shadow:0 0 0 4px color-mix(in oklch, var(--accent) 18%, transparent);
    }
    .nav-links{
      display:flex; gap:28px; align-items:center;
      font-size:14px; color:var(--fg-soft);
    }
    .nav-links a:hover{color:var(--accent-deep)}
    .nav-right{display:flex; align-items:center; gap:14px}

    .lang{
      display:inline-flex; align-items:stretch;
      border:1px solid var(--border-strong);
      border-radius:999px;
      font-family:var(--font-mono);
      font-size:11px; letter-spacing:0.08em;
      overflow:hidden;
    }
    .lang button{
      padding:6px 12px;
      color:var(--muted);
      transition:background .15s, color .15s;
    }
    .lang button[aria-pressed="true"]{
      background:var(--fg);
      color:var(--bg);
    }

    .btn{
      display:inline-flex; align-items:center; gap:8px;
      padding:11px 18px;
      border-radius:999px;
      font-size:14px; font-weight:500;
      letter-spacing:-0.005em;
      transition:transform .15s, background .15s, color .15s, border-color .15s;
      white-space:nowrap;
    }
    .btn-primary{
      background:var(--fg);
      color:var(--bg);
    }
    .btn-primary:hover{background:var(--accent-deep)}
    .btn-accent{
      background:var(--accent);
      color:#fff;
    }
    .btn-accent:hover{background:var(--accent-deep); transform:translateY(-1px)}
    .btn-ghost{
      color:var(--fg-soft);
      border:1px solid var(--border-strong);
    }
    .btn-ghost:hover{border-color:var(--fg); color:var(--fg)}
    .btn-large{
      padding:16px 26px;
      font-size:15px;
    }
    .btn .arr{transition:transform .2s}
    .btn:hover .arr{transform:translateX(3px)}

    .mobile-toggle{display:none}

    /* ── Hero ────────────────────────────────────────────── */
    .hero{
      padding-top:clamp(48px, 7vw, 96px);
      padding-bottom:clamp(48px, 7vw, 88px);
      position:relative;
      overflow:hidden;
    }
    .hero-grid{
      display:grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
      gap:clamp(36px, 5vw, 80px);
      align-items:center;
    }
    .hero h1{
      font-size:clamp(48px, 7vw, 92px);
      margin:18px 0 22px;
      max-width:14ch;
    }
    .hero h1 em{
      font-style:italic;
      color:var(--accent-deep);
      font-weight:400;
    }
    .hero-cta{
      display:flex; gap:14px; flex-wrap:wrap;
      margin-top:30px;
    }
    .hero-meta{
      display:flex; gap:28px;
      margin-top:42px;
      padding-top:24px;
      border-top:1px solid var(--border);
      flex-wrap:wrap;
    }
    .hero-meta-item .k{font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--muted); font-family:var(--font-mono)}
    .hero-meta-item .v{font-family:var(--font-display); font-size:22px; font-weight:500; margin-top:4px}

    .hero-visual{
      position:relative;
      aspect-ratio:4/5;
      border-radius:var(--radius-lg);
      overflow:hidden;
      box-shadow:var(--shadow-1);
    }
    .hero-visual .ph{height:100%}
    .hero-stamp{
      position:absolute;
      left:20px; bottom:20px;
      background:color-mix(in oklch, var(--bg) 92%, transparent);
      backdrop-filter:blur(8px);
      border:1px solid var(--border);
      padding:12px 16px;
      border-radius:14px;
      font-size:12px;
      display:flex; align-items:center; gap:10px;
    }
    .hero-stamp .pin{
      width:10px;height:10px;border-radius:50%;
      background:var(--coral);
      box-shadow:0 0 0 4px color-mix(in oklch, var(--coral) 22%, transparent);
    }

    /* ── Placeholders for images ─────────────────────────── */
    .ph{
      position:relative;
      width:100%;
      background:
        radial-gradient(ellipse at 30% 20%, color-mix(in oklch, var(--ocean-50) 70%, white), transparent 60%),
        radial-gradient(ellipse at 80% 90%, color-mix(in oklch, var(--sand-50) 80%, white), transparent 55%),
        linear-gradient(160deg, var(--ocean-50), var(--sand-50));
      overflow:hidden;
    }
    .ph::before{
      content:"";
      position:absolute; inset:0;
      background:
        repeating-linear-gradient(135deg,
          transparent 0 18px,
          color-mix(in oklch, var(--accent) 6%, transparent) 18px 19px);
      opacity:.4;
    }
    .ph::after{
      content: attr(data-label);
      position:absolute;
      left:14px; top:14px;
      max-width:calc(100% - 28px);
      padding:6px 10px;
      font:11px/1.4 var(--font-mono);
      letter-spacing:0.04em;
      color:var(--fg);
      background:color-mix(in oklch, var(--bg) 92%, transparent);
      border:1px solid var(--border);
      border-radius:6px;
      backdrop-filter:blur(6px);
    }
    .ph.ph-4-3{aspect-ratio:4/3}
    .ph.ph-3-4{aspect-ratio:3/4}
    .ph.ph-16-9{aspect-ratio:16/9}
    .ph.ph-1-1{aspect-ratio:1/1}

    /* ── Intro ───────────────────────────────────────────── */
    section{padding-block:var(--space-section)}
    .section-head{
      display:grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      gap:clamp(32px, 5vw, 80px);
      align-items:end;
      margin-bottom:clamp(40px, 5vw, 64px);
    }
    .section-head h2{
      font-size:clamp(36px, 4.6vw, 60px);
      margin:14px 0 0;
      max-width:18ch;
    }
    .section-head p{margin:0}

    .rent-options{
      display:flex; flex-wrap:wrap; gap:10px;
      margin-top:20px;
    }
    .rent-pill{
      display:inline-flex; align-items:center; gap:10px;
      padding:8px 14px 8px 8px;
      border:1px solid var(--border);
      border-radius:999px;
      background:var(--surface);
      font-size:13px;
      color:var(--fg-soft);
    }
    .rent-pill .rent-num{
      display:grid; place-items:center;
      width:22px; height:22px;
      border-radius:50%;
      background:var(--ocean-50);
      color:var(--accent-deep);
      font-family:var(--font-mono);
      font-size:11px;
      font-weight:600;
    }
    .rent-pill-accent{
      border-color:color-mix(in oklch, var(--coral) 35%, var(--border));
      background:color-mix(in oklch, var(--coral) 7%, var(--surface));
      color:var(--fg);
    }
    .rent-pill-accent .rent-num{
      background:var(--coral);
      color:#fff;
    }
    .shared-note{
      margin:18px 0 0;
      font-size:13.5px;
      color:var(--fg-soft);
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:10px 14px;
      border-top:1px solid var(--border);
      border-bottom:1px solid var(--border);
      font-family:var(--font-mono);
      letter-spacing:0.02em;
    }
    .shared-note strong{
      color:var(--fg);
      font-weight:600;
      font-family:var(--font-body);
      letter-spacing:0;
    }
    .shared-note .ico{
      display:inline-flex;
      width:18px; height:18px;
      color:var(--accent-deep);
      flex-shrink:0;
    }

    .intro{
      border-top:1px solid var(--border);
      border-bottom:1px solid var(--border);
      padding-block:clamp(72px, 9vw, 120px);
    }
    .intro-quote{
      font-family:var(--font-display);
      font-size:clamp(32px, 4vw, 52px);
      line-height:1.18;
      font-weight:400;
      letter-spacing:-0.012em;
      max-width:22ch;
      margin:0 auto;
      text-align:center;
      color:var(--fg);
    }
    .intro-quote em{
      font-style:italic;
      color:var(--accent-deep);
    }
    .intro-byline{
      text-align:center;
      margin-top:28px;
      color:var(--muted);
      font-size:13px;
      letter-spacing:0.06em;
      font-family:var(--font-mono);
      text-transform:uppercase;
    }

    /* ── Módulos ─────────────────────────────────────────── */
    .modules{
      display:grid;
      grid-template-columns:repeat(3, minmax(0,1fr));
      gap:24px;
    }
    .module{
      display:flex; flex-direction:column;
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:var(--radius);
      overflow:hidden;
      transition:border-color .2s, transform .2s;
    }
    .module:hover{
      border-color:var(--border-strong);
      transform:translateY(-2px);
    }
    .module .ph{aspect-ratio:4/3}
    .module-body{padding:24px 22px 26px; display:flex; flex-direction:column; gap:14px; flex:1}
    .module-tag{
      align-self:flex-start;
      font-family:var(--font-mono);
      font-size:10px;
      letter-spacing:0.12em;
      text-transform:uppercase;
      color:var(--accent-deep);
      background:color-mix(in oklch, var(--accent) 12%, transparent);
      padding:4px 9px;
      border-radius:999px;
    }
    .module-tag.coral{
      color:oklch(48% 0.14 35);
      background:color-mix(in oklch, var(--coral) 14%, transparent);
    }
    .module h3{
      font-family:var(--font-display);
      font-size:30px;
      font-weight:500;
      margin:0;
      letter-spacing:-0.01em;
    }
    .module p{
      margin:0;
      color:var(--fg-soft);
      font-size:15px;
      line-height:1.55;
    }
    .specs{
      display:flex; flex-wrap:wrap; gap:8px;
      margin-top:auto;
    }
    .spec{
      display:inline-flex; align-items:center; gap:6px;
      font-size:12px;
      color:var(--fg-soft);
      border:1px solid var(--border);
      padding:6px 10px;
      border-radius:999px;
      background:var(--surface-2);
    }
    .spec svg{width:14px; height:14px; flex-shrink:0; color:var(--accent-deep)}
    .module-foot{
      display:flex; justify-content:space-between; align-items:center;
      padding:16px 22px;
      border-top:1px solid var(--border);
      background:var(--surface-2);
    }
    .module-foot .price{
      font-family:var(--font-mono);
      font-size:11px;
      letter-spacing:0.08em;
      color:var(--muted);
      text-transform:uppercase;
    }
    .module-foot a{
      font-size:13px;
      color:var(--accent-deep);
      font-weight:500;
      display:inline-flex; gap:6px; align-items:center;
    }
    .module-foot a:hover{color:var(--fg)}

    /* ── Galería ─────────────────────────────────────────── */
    .gallery{
      display:grid;
      grid-template-columns:repeat(12, 1fr);
      grid-auto-rows:120px;
      gap:14px;
    }
    .g{
      border-radius:var(--radius);
      overflow:hidden;
    }
    .g.g1{grid-column:span 7; grid-row:span 3}
    .g.g2{grid-column:span 5; grid-row:span 2}
    .g.g3{grid-column:span 5; grid-row:span 2}
    .g.g4{grid-column:span 4; grid-row:span 2}
    .g.g5{grid-column:span 4; grid-row:span 2}
    .g.g6{grid-column:span 4; grid-row:span 2}
    .g .ph{height:100%}

    /* ── Ubicación ───────────────────────────────────────── */
    .location-grid{
      display:grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      gap:clamp(28px, 4vw, 56px);
      align-items:stretch;
    }
    .map{
      border:1px solid var(--border);
      border-radius:var(--radius);
      overflow:hidden;
      min-height:440px;
      position:relative;
      background:
        radial-gradient(ellipse at 30% 35%, color-mix(in oklch, var(--ocean-50) 90%, white), transparent 55%),
        radial-gradient(ellipse at 80% 70%, color-mix(in oklch, var(--sand-50) 80%, white), transparent 50%),
        var(--ocean-50);
    }
    .map svg{position:absolute; inset:0; width:100%; height:100%}
    .map-pin{
      position:absolute;
      top:46%; left:38%;
      transform:translate(-50%,-50%);
      display:flex; flex-direction:column; align-items:center; gap:8px;
    }
    .map-pin .dot{
      width:18px;height:18px;border-radius:50%;
      background:var(--coral);
      box-shadow:0 0 0 6px color-mix(in oklch, var(--coral) 25%, transparent),
                 0 0 0 14px color-mix(in oklch, var(--coral) 10%, transparent);
    }
    .map-pin .label{
      font-family:var(--font-display);
      font-size:18px; font-weight:500;
      background:var(--surface);
      padding:5px 12px;
      border-radius:8px;
      border:1px solid var(--border);
      box-shadow:var(--shadow-1);
    }
    .map-legend{
      position:absolute;
      left:18px; bottom:18px;
      background:color-mix(in oklch, var(--bg) 92%, transparent);
      border:1px solid var(--border);
      border-radius:10px;
      padding:10px 14px;
      font-family:var(--font-mono);
      font-size:11px;
      letter-spacing:0.06em;
      color:var(--muted);
      backdrop-filter:blur(6px);
    }

    .nearby{
      display:flex; flex-direction:column;
      gap:0;
    }
    .nearby h3{
      font-family:var(--font-display);
      font-size:28px; font-weight:500;
      margin:0 0 18px;
    }
    .nearby-list{
      display:flex; flex-direction:column;
      border-top:1px solid var(--border);
    }
    .nearby-item{
      display:grid;
      grid-template-columns: 38px 1fr auto;
      align-items:center;
      gap:18px;
      padding:18px 0;
      border-bottom:1px solid var(--border);
    }
    .nearby-icon{
      width:38px;height:38px;
      border-radius:10px;
      background:var(--ocean-50);
      color:var(--accent-deep);
      display:grid; place-items:center;
    }
    .nearby-icon svg{width:18px; height:18px}
    .nearby-name{font-weight:500; color:var(--fg)}
    .nearby-desc{font-size:13px; color:var(--muted); margin-top:2px}
    .nearby-dist{
      font-family:var(--font-mono);
      font-size:12px;
      color:var(--fg-soft);
      letter-spacing:0.04em;
      white-space:nowrap;
    }

    /* ── Testimonios ─────────────────────────────────────── */
    .testimonials{
      background:var(--surface-2);
      border-top:1px solid var(--border);
      border-bottom:1px solid var(--border);
    }
    .t-grid{
      display:grid;
      grid-template-columns:repeat(3, minmax(0, 1fr));
      gap:24px;
    }
    .t{
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:var(--radius);
      padding:30px 26px 26px;
      display:flex; flex-direction:column; gap:18px;
    }
    .t-stars{
      display:flex; gap:2px;
      color:var(--coral);
    }
    .t-stars svg{width:16px;height:16px}
    .t-quote{
      font-family:var(--font-display);
      font-size:22px;
      line-height:1.32;
      font-weight:400;
      color:var(--fg);
      margin:0;
      letter-spacing:-0.005em;
    }
    .t-author{
      display:flex; align-items:center; gap:12px;
      margin-top:auto;
      padding-top:18px;
      border-top:1px solid var(--border);
    }
    .t-avatar{
      width:38px; height:38px; border-radius:50%;
      background:linear-gradient(135deg, var(--ocean-50), var(--sand-50));
      border:1px solid var(--border);
      display:grid; place-items:center;
      font-family:var(--font-display);
      font-weight:500;
      color:var(--fg);
    }
    .t-author .n{font-size:14px; font-weight:500}
    .t-author .m{font-size:12px; color:var(--muted); font-family:var(--font-mono); letter-spacing:0.04em}

    /* ── Contacto / CTA ──────────────────────────────────── */
    .contact{
      padding-block:clamp(80px, 10vw, 140px);
      position:relative;
      overflow:hidden;
    }
    .contact-card{
      background:var(--fg);
      color:var(--bg);
      border-radius:var(--radius-lg);
      padding:clamp(40px, 6vw, 80px) clamp(28px, 5vw, 72px);
      position:relative;
      overflow:hidden;
    }
    .contact-card::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(ellipse at 100% 0%, color-mix(in oklch, var(--accent) 35%, transparent), transparent 55%),
        radial-gradient(ellipse at 0% 100%, color-mix(in oklch, var(--coral) 20%, transparent), transparent 55%);
      pointer-events:none;
    }
    .contact-grid{
      display:grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
      gap:clamp(28px, 5vw, 60px);
      align-items:end;
      position:relative;
      z-index:1;
    }
    .contact h2{
      font-family:var(--font-display);
      font-size:clamp(36px, 4.6vw, 56px);
      margin:14px 0 16px;
      line-height:1.08;
      letter-spacing:-0.015em;
      max-width:18ch;
      color:var(--bg);
    }
    .contact p.lead{color:color-mix(in oklch, var(--bg) 78%, transparent)}
    .contact .eyebrow{color:color-mix(in oklch, var(--accent) 60%, white)}
    .contact .eyebrow::before{background:currentColor}
    .contact-actions{
      display:flex; flex-direction:column; gap:14px;
    }
    .contact-actions .btn-accent{
      background:#fff; color:var(--fg);
    }
